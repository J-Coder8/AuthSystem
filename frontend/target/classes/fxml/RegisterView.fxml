<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.authsystem.controller.RegisterController">

    <VBox spacing="20" alignment="CENTER" styleClass="container">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <!-- Header -->
        <VBox spacing="5" alignment="CENTER">
            <HBox alignment="CENTER_LEFT">
                <Button text="Back" styleClass="btn-secondary" onAction="#handleLogin"/>
            </HBox>
            <Label text="Create Account" styleClass="header-label"/>
            <Label text="Sign up for a new account" styleClass="sub-header-label"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="12" maxWidth="300">
            <!-- Username Field -->
            <VBox spacing="5">
                <Label text="Username"/>
                <TextField fx:id="usernameField" promptText="Enter username (3-50 chars)"/>
            </VBox>

            <!-- Email Field -->
            <VBox spacing="5">
                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="Enter your email"/>
            </VBox>

            <!-- Full Name Field -->
            <VBox spacing="5">
                <Label text="Full Name"/>
                <TextField fx:id="fullNameField" promptText="Enter your full name"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5">
                <Label text="Password"/>
                <PasswordField fx:id="passwordField" promptText="8+ chars, uppercase, lowercase, number"
                               onKeyReleased="#handlePasswordInput"/>
            </VBox>

            <!-- Password Strength Indicator -->
            <Label fx:id="passwordStrengthLabel" text="" styleClass="password-strength"/>

            <!-- Confirm Password Field -->
            <VBox spacing="5">
                <Label text="Confirm Password"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"
                               onKeyReleased="#handleConfirmPasswordInput"/>
            </VBox>

            <Label fx:id="passwordMatchLabel" text="" styleClass="password-strength"/>

            <!-- Error/Success Message -->
            <Label fx:id="messageLabel" text="" wrapText="true"/>

            <!-- Register Button -->
            <Button fx:id="registerButton" text="Register" styleClass="btn-primary" 
                    onAction="#handleRegister" maxWidth="Infinity"/>

            <!-- Progress Indicator -->
            <ProgressIndicator fx:id="progressIndicator" progress="-1" 
                              visible="false" maxWidth="30" maxHeight="30"/>
        </VBox>

        <!-- Login Link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?" styleClass="label"/>
            <Button text="Login" styleClass="btn-secondary" onAction="#handleLogin"/>
        </HBox>
    </VBox>
</StackPane>
