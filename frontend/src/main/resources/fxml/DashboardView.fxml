<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.authsystem.controller.DashboardController" styleClass="dashboard-shell">

    <!-- Top Section - User Info -->
    <top>
        <VBox styleClass="dashboard-topbar">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Authentication System" styleClass="system-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="top-meta-primary"/>
                    <Label fx:id="emailLabel" text="user@email.com" styleClass="top-meta-secondary"/>
                    <Label fx:id="unreadAlertsLabel" text="Alerts: 0" styleClass="top-alerts"/>
                </VBox>
                <Button fx:id="adminPanelBtn" text="Admin Panel" styleClass="btn-admin"
                        onAction="#handleOpenAdminPanel" visible="false">
                    <tooltip>
                        <Tooltip text="Open Admin Panel"/>
                    </tooltip>
                </Button>
                <Button fx:id="themeToggleBtn" text="Dark Mode" styleClass="btn-secondary"
                        onAction="#handleThemeToggle">
                    <tooltip>
                        <Tooltip text="Switch between light and dark mode"/>
                    </tooltip>
                </Button>
                <Button text="Logout" styleClass="btn-secondary" 
                        onAction="#handleLogout"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center Section - Tabbed Content -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;" styleClass="dashboard-tabs">
            
            <!-- Tab 1: Dashboard Overview -->
            <Tab text="Dashboard">
                <VBox spacing="20" style="-fx-padding: 20;" styleClass="dashboard-content">
                    <Label text="Account Overview" styleClass="header-label"/>
                    
                    <!-- Statistics Cards -->
                    <FlowPane hgap="16" vgap="16" prefWrapLength="980" alignment="CENTER_LEFT" styleClass="stats-grid">
                        <VBox styleClass="stat-card stat-card-blue overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Total Logins" styleClass="stat-label"/>
                            <Label fx:id="totalLoginsLabel" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-teal overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Active Sessions" styleClass="stat-label"/>
                            <Label fx:id="totalSessionsLabel" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-green overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Security Score" styleClass="stat-label"/>
                            <Label fx:id="securityScoreLabel" text="N/A" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-orange overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Account Age" styleClass="stat-label"/>
                            <Label fx:id="accountAgeLabel" text="N/A" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-purple overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Unread Alerts" styleClass="stat-label"/>
                            <Label fx:id="unreadStatsLabel" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-red overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Profile Status" styleClass="stat-label"/>
                            <Label fx:id="profileStatusStatLabel" text="N/A" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-green overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Backup Codes" styleClass="stat-label"/>
                            <Label fx:id="backupCodesStatLabel" text="None" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card stat-card-blue overview-stat-card" prefWidth="168" prefHeight="106" alignment="CENTER_LEFT">
                            <Label text="Last Seen" styleClass="stat-label"/>
                            <Label fx:id="lastSeenStatLabel" text="Never" styleClass="stat-value stat-value-small"/>
                        </VBox>
                    </FlowPane>
                    
                    <!-- Last Login Info -->
                    <VBox styleClass="card" spacing="10">
                        <Label text="Last Login Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <HBox spacing="30">
                            <VBox>
                                <Label text="IP Address:" styleClass="label-secondary"/>
                                <Label fx:id="lastLoginIpLabel" text="N/A" styleClass="label-primary"/>
                            </VBox>
                            <VBox>
                                <Label text="Device:" styleClass="label-secondary"/>
                                <Label fx:id="lastLoginDeviceLabel" text="N/A" styleClass="label-primary"/>
                            </VBox>
                            <VBox>
                                <Label text="Time:" styleClass="label-secondary"/>
                                <Label fx:id="lastLoginTimeLabel" text="N/A" styleClass="label-primary"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    
                    <!-- Quick Actions -->
                    <FlowPane hgap="10" vgap="10" prefWrapLength="620" styleClass="quick-action-bar">
                        <Button text="Edit Profile" styleClass="btn-primary" onAction="#handleEditProfile"/>
                        <Button text="Change Password" styleClass="btn-primary" onAction="#handleChangePassword"/>
                        <Button text="Register Face Recognition" styleClass="btn-primary" onAction="#handleRegisterFace"/>
                        <Button text="Refresh" styleClass="btn-secondary" onAction="#handleRefresh"/>
                    </FlowPane>

                    <!-- Snapshot + Profile Completeness -->
                    <HBox spacing="20" styleClass="insight-row">
                        <VBox styleClass="card" spacing="8" prefWidth="320">
                            <Label text="Security Snapshot" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label fx:id="snapshotTotpLabel" text="TOTP: N/A" styleClass="label-secondary"/>
                            <Label fx:id="snapshotFaceLabel" text="Face Login: N/A" styleClass="label-secondary"/>
                            <Label fx:id="snapshotAccountLabel" text="Account: N/A" styleClass="label-secondary"/>
                        </VBox>

                        <VBox styleClass="card" spacing="8" prefWidth="320">
                            <Label text="Profile Completeness" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <ProgressBar fx:id="profileCompletionBar" prefWidth="260"/>
                            <Label fx:id="profileCompletionLabel" text="0% complete" styleClass="label-secondary"/>
                        </VBox>
                    </HBox>

                    <!-- Recent Activity -->
                    <VBox styleClass="card" spacing="10">
                        <Label text="Recent Activity" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <ListView fx:id="recentActivityList" prefHeight="140" maxWidth="700"/>
                    </VBox>
                </VBox>
            </Tab>
            
            <!-- Tab 2: Login History -->
            <Tab text="Login History">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Recent Login Activity" styleClass="header-label"/>

                    <TableView fx:id="historyTable" maxWidth="700" maxHeight="400">
                        <columns>
                            <TableColumn text="Time" prefWidth="150">
                                <cellValueFactory>
                                    <PropertyValueFactory property="loginTime"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="IP Address" prefWidth="130">
                                <cellValueFactory>
                                    <PropertyValueFactory property="ipAddress"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Device" prefWidth="200">
                                <cellValueFactory>
                                    <PropertyValueFactory property="userAgent"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Status" prefWidth="80">
                                <cellValueFactory>
                                    <PropertyValueFactory property="success"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Risk" prefWidth="80">
                                <cellValueFactory>
                                    <PropertyValueFactory property="riskScore"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Details" prefWidth="140">
                                <cellValueFactory>
                                    <PropertyValueFactory property="failureReason"/>
                                </cellValueFactory>
                            </TableColumn>
                        </columns>
                    </TableView>

                    <HBox spacing="10">
                        <Button text="Refresh History" styleClass="btn-primary" onAction="#handleRefresh"/>
                        <Button text="Export CSV" styleClass="btn-secondary" onAction="#handleExportHistory"/>
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Tab 3: Session Management -->
            <Tab text="Sessions">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Active Sessions" styleClass="header-label"/>
                    
                    <VBox styleClass="card" spacing="10">
                        <Label text="Manage your active sessions across devices" styleClass="label-secondary"/>
                        
                        <TableView fx:id="sessionsTable" prefWidth="1040" prefHeight="320" maxHeight="320" styleClass="session-table">
                            <columns>
                                <TableColumn text="Device" prefWidth="180">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="device"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="IP Address" prefWidth="130">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="ipAddress"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Last Active" prefWidth="150">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="lastActive"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Current" prefWidth="80">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="current"/>
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="Action" prefWidth="160">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="sessionId"/>
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox styleClass="card session-details-card" spacing="6">
                        <Label text="Selected Session Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label fx:id="sessionDeviceLabel" text="Device: N/A" styleClass="label-secondary"/>
                        <Label fx:id="sessionIpLabel" text="IP Address: N/A" styleClass="label-secondary"/>
                        <Label fx:id="sessionLastActiveLabel" text="Last Active: N/A" styleClass="label-secondary"/>
                        <Label fx:id="sessionCurrentLabel" text="Current Session: N/A" styleClass="label-secondary"/>
                        <Label fx:id="sessionIdLabel" text="Session ID: N/A" styleClass="label-secondary"/>
                    </VBox>

                    <HBox spacing="10">
                        <Button text="Refresh Sessions" styleClass="btn-primary" onAction="#handleRefreshSessions"/>
                        <Button text="Logout All Devices" styleClass="btn-danger" onAction="#handleLogoutAllDevices"/>
                        <Button text="Revoke Selected" styleClass="btn-warning" onAction="#handleRevokeSelectedSession"/>
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Tab 4: Security Settings -->
            <Tab text="Security">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 20;">
                            <Label text="Security Settings" styleClass="header-label"/>

                            <!-- TOTP Settings -->
                            <VBox styleClass="card security-card" spacing="10">
                                <Label text="Two-Factor Authentication (TOTP)" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label fx:id="totpStatusLabel" text="TOTP is not enabled" styleClass="label-secondary"/>
                                <HBox spacing="10">
                                    <Button fx:id="enableTotpBtn" text="Enable TOTP" styleClass="btn-primary" onAction="#handleEnableTotp"/>
                                    <Button fx:id="disableTotpBtn" text="Disable TOTP" styleClass="btn-secondary" onAction="#handleDisableTotp" visible="false"/>
                                </HBox>
                            </VBox>

                            <VBox fx:id="totpLiveCard" styleClass="card security-card security-highlight-card" spacing="8" visible="false">
                                <Label text="Authenticator Code (30s)" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label fx:id="totpLiveCodeLabel" text="------" styleClass="totp-code"/>
                                <Label fx:id="totpLiveCountdownLabel" text="Refreshes in: --s" styleClass="label-secondary"/>
                                <HBox spacing="10">
                                    <Button text="Refresh Code" styleClass="btn-secondary" onAction="#handleRefreshTotpLive"/>
                                </HBox>
                            </VBox>

                            <VBox styleClass="card security-card" spacing="10">
                                <Label text="Backup Codes" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label fx:id="backupCodesStatusLabel" text="No backup codes generated yet" styleClass="label-secondary"/>
                                <HBox spacing="10">
                                    <Button text="Generate Backup Codes" styleClass="btn-primary" onAction="#handleGenerateBackupCodes"/>
                                </HBox>
                            </VBox>

                            <!-- Face Recognition Settings -->
                            <VBox styleClass="card security-card" spacing="10">
                                <Label text="Face Recognition Login" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label fx:id="faceStatusLabel" text="Face login is not configured" styleClass="label-secondary"/>
                                <HBox spacing="10">
                                    <Button fx:id="registerFaceBtn" text="Register Face Recognition" styleClass="btn-primary" onAction="#handleRegisterFace"/>
                                    <Button fx:id="viewFaceStatusBtn" text="View Status" styleClass="btn-secondary" onAction="#handleViewFaceStatus"/>
                                    <Button fx:id="enableFaceLoginBtn" text="Enable Face Login" styleClass="btn-primary" onAction="#handleEnableFaceLogin" visible="false"/>
                                    <Button fx:id="disableFaceLoginBtn" text="Disable Face Login" styleClass="btn-secondary" onAction="#handleDisableFaceLogin" visible="false"/>
                                    <Button text="Trust This Device" styleClass="btn-warning" onAction="#handleTrustDevice"/>
                                </HBox>
                            </VBox>

                            <VBox styleClass="card security-card security-checklist-card" spacing="8">
                                <Label text="Security Checklist" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <CheckBox fx:id="checkTotp" text="Enable two-factor (TOTP)" disable="true"/>
                                <CheckBox fx:id="checkFace" text="Register face login" disable="true"/>
                                <CheckBox fx:id="checkProfile" text="Complete your profile" disable="true"/>
                                <CheckBox fx:id="checkAlerts" text="Turn on login alerts" disable="true"/>
                            </VBox>

                            <!-- Password Settings -->
                            <VBox styleClass="card security-card" spacing="10">
                                <Label text="Password" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label text="Last changed: Never" styleClass="label-secondary" fx:id="passwordChangedLabel"/>
                                <Button text="Change Password" styleClass="btn-primary" onAction="#handleChangePassword"/>
                            </VBox>

                            <!-- Account Status -->
                            <VBox styleClass="card security-card" spacing="10">
                                <Label text="Account Status" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <HBox spacing="20">
                                    <Label fx:id="accountStatusLabel" text="Active" style="-fx-text-fill: #27ae60;"/>
                                    <Label fx:id="roleLabel" text="Role: USER" styleClass="label-secondary"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- Tab 5: Authenticator Vault -->
            <Tab text="Authenticator">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Authenticator Vault" styleClass="header-label"/>

                    <VBox styleClass="card" spacing="8">
                        <Label fx:id="authenticatorStatusLabel" text="Codes refresh every 30 seconds" styleClass="label-secondary"/>
                        <Label fx:id="authenticatorCountdownLabel" text="Refreshes in: --s" styleClass="label-secondary"/>
                        <HBox spacing="10">
                            <Button text="Add Account" styleClass="btn-primary" onAction="#handleAddAuthenticatorAccount"/>
                            <Button text="Delete Selected" styleClass="btn-warning" onAction="#handleDeleteAuthenticatorAccount"/>
                            <Button text="Refresh Codes" styleClass="btn-secondary" onAction="#handleRefreshAuthenticatorCodes"/>
                        </HBox>
                    </VBox>

                    <TableView fx:id="authenticatorTable" maxWidth="760" maxHeight="360">
                        <columns>
                            <TableColumn fx:id="authenticatorIssuerColumn" text="Issuer" prefWidth="160">
                                <cellValueFactory>
                                    <PropertyValueFactory property="issuer"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="authenticatorAccountColumn" text="Account" prefWidth="220">
                                <cellValueFactory>
                                    <PropertyValueFactory property="accountName"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="authenticatorCodeColumn" text="Code" prefWidth="140">
                                <cellValueFactory>
                                    <PropertyValueFactory property="code"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn fx:id="authenticatorRemainingColumn" text="Refresh" prefWidth="90">
                                <cellValueFactory>
                                    <PropertyValueFactory property="remainingSeconds"/>
                                </cellValueFactory>
                            </TableColumn>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab 6: Notifications -->
            <Tab text="Notifications">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Security &amp; System Notifications" styleClass="header-label"/>

                    <TableView fx:id="notificationsTable" maxWidth="760" maxHeight="360">
                        <columns>
                            <TableColumn text="Time" prefWidth="150">
                                <cellValueFactory>
                                    <PropertyValueFactory property="createdAt"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Title" prefWidth="180">
                                <cellValueFactory>
                                    <PropertyValueFactory property="title"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Type" prefWidth="100">
                                <cellValueFactory>
                                    <PropertyValueFactory property="type"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Severity" prefWidth="90">
                                <cellValueFactory>
                                    <PropertyValueFactory property="severity"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Read" prefWidth="70">
                                <cellValueFactory>
                                    <PropertyValueFactory property="read"/>
                                </cellValueFactory>
                            </TableColumn>
                            <TableColumn text="Message" prefWidth="260">
                                <cellValueFactory>
                                    <PropertyValueFactory property="message"/>
                                </cellValueFactory>
                            </TableColumn>
                        </columns>
                    </TableView>

                    <HBox spacing="10">
                        <Button text="Refresh" styleClass="btn-primary" onAction="#handleRefreshNotifications"/>
                        <Button text="Mark Read" styleClass="btn-secondary" onAction="#handleMarkNotificationRead"/>
                        <Button text="Mark All Read" styleClass="btn-secondary" onAction="#handleMarkAllNotificationsRead"/>
                        <Button text="Delete" styleClass="btn-warning" onAction="#handleDeleteNotification"/>
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Tab 7: Settings -->
            <Tab text="Settings">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 20;">
                            <Label text="Account Settings" styleClass="header-label"/>

                            <!-- Theme Settings -->
                            <VBox styleClass="card design-studio-card" spacing="12">
                                <Label text="Appearance Studio" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <Label text="Switch presets or paste custom JavaFX CSS to redesign the app your way." styleClass="label-secondary" wrapText="true"/>
                                <GridPane hgap="12" vgap="12">
                                    <Label text="Visual Preset:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <ComboBox fx:id="designPresetCombo" prefWidth="260" onAction="#handleDesignPresetChange" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Label text="Dark Mode:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <CheckBox fx:id="darkModeCheck" text="Enable Dark Mode" onAction="#handleDarkModeToggle" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <Label text="Starter CSS:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <ComboBox fx:id="designTemplateCombo" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                </GridPane>
                                <Label text="Custom Design CSS" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <TextArea fx:id="customCssArea" prefRowCount="8" wrapText="false"
                                          promptText=".root { -fx-background-color: #101418; }&#10;.card { -fx-background-color: #182026; }"/>
                                <HBox spacing="10">
                                    <Button text="Load Starter CSS" styleClass="btn-secondary" onAction="#handleLoadDesignTemplate"/>
                                    <Button text="Apply Custom Design" styleClass="btn-primary" onAction="#handleApplyCustomDesign"/>
                                    <Button text="Clear Custom Design" styleClass="btn-secondary" onAction="#handleResetCustomDesign"/>
                                </HBox>
                                <Label fx:id="designStatusLabel" text="Preset styling is active." styleClass="label-secondary" wrapText="true"/>
                            </VBox>

                            <!-- Notification Settings -->
                            <VBox styleClass="card" spacing="10">
                                <Label text="Notifications" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <CheckBox fx:id="emailNotificationsCheck" text="Email Notifications" onAction="#handleNotificationToggle"/>
                                <CheckBox fx:id="loginAlertsCheck" text="Login Alerts" onAction="#handleNotificationToggle"/>
                            </VBox>

                            <!-- Profile Information -->
                            <VBox styleClass="card" spacing="10">
                                <Label text="Profile Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                <GridPane hgap="10" vgap="10">
                                    <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Label fx:id="usernameLabel" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Label fx:id="settingsEmailLabel" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                    <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <Label fx:id="fullNameLabel" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                    <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                    <Label fx:id="phoneLabel" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                </GridPane>
                                <Button text="Edit Profile" styleClass="btn-primary" onAction="#handleEditProfile"/>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
