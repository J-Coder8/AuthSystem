<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.authsystem.controller.LoginController">

    <VBox spacing="20" alignment="CENTER" styleClass="container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Header -->
        <VBox spacing="5" alignment="CENTER">
            <HBox alignment="CENTER_LEFT">
                <Button text="Create Account" styleClass="btn-secondary" onAction="#handleRegister"/>
            </HBox>
            <Label text="Welcome Back" styleClass="header-label"/>
            <Label text="Sign in and we&apos;ll generate an OTP in the backend console automatically" styleClass="sub-header-label" wrapText="true"/>
        </VBox>

<!-- Form -->
        <VBox spacing="15" maxWidth="300">
            <!-- Email/Username Field -->
            <VBox spacing="5">
                <Label text="Email or Username"/>
                <TextField fx:id="usernameField" promptText="Enter your email or username (e.g., john or john@gmail.com)"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Password"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"/>
            </VBox>

            <!-- Error Message -->
            <Label fx:id="errorLabel" text="" styleClass="label-error" wrapText="true"/>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Login" styleClass="btn-primary" 
                    onAction="#handleLogin" maxWidth="Infinity"/>

            <!-- Progress Indicator -->
            <ProgressIndicator fx:id="progressIndicator" progress="-1" 
                              visible="false" maxWidth="30" maxHeight="30"/>
        </VBox>

<!-- Register Link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?" styleClass="label"/>
            <Button text="Register" styleClass="btn-secondary" onAction="#handleRegister"/>
        </HBox>
        
        <!-- Forgot Password Link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Forgot your password?" styleClass="label"/>
            <Button text="Reset Password" styleClass="btn-secondary" onAction="#handleForgotPassword"/>
        </HBox>
        
        <!-- Face Login Link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Or login with" styleClass="label"/>
            <Button text="Face Recognition" styleClass="btn-secondary" onAction="#handleFaceLogin"/>
        </HBox>
    </VBox>
</StackPane>
