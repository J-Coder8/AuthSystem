<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.authsystem.controller.ForgotPasswordController">

    <VBox spacing="20" alignment="CENTER" styleClass="container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Header -->
        <VBox spacing="5" alignment="CENTER">
            <HBox alignment="CENTER_LEFT">
                <Button text="Back" styleClass="btn-secondary" onAction="#handleBack"/>
            </HBox>
            <Label text="Forgot Password" styleClass="header-label"/>
            <Label text="Use your username or email and get a reset code from the backend console" styleClass="sub-header-label" wrapText="true"/>
        </VBox>

        <!-- Request OTP Form -->
        <VBox fx:id="requestForm" spacing="15" maxWidth="300">
            <VBox spacing="5">
                <Label text="Username or Email"/>
                <TextField fx:id="identifierField" promptText="Enter your username or registered email"/>
            </VBox>

            <Label fx:id="errorLabel" text="" styleClass="label-error" wrapText="true"/>
            <Label fx:id="successLabel" text="" styleClass="label-success" wrapText="true"/>

            <Button fx:id="sendOtpButton" text="Generate Reset OTP" styleClass="btn-primary" 
                    onAction="#handleSendOtp" maxWidth="Infinity"/>

            <ProgressIndicator fx:id="progressIndicator" progress="-1" 
                              visible="false" maxWidth="30" maxHeight="30"/>
        </VBox>

        <!-- Reset Password Form (hidden initially) -->
        <VBox fx:id="resetForm" spacing="15" maxWidth="300" visible="false">
            <VBox spacing="5">
                <Label text="Username or Email"/>
                <TextField fx:id="resetIdentifierField" promptText="Account identifier" editable="false"/>
            </VBox>

            <VBox spacing="5">
                <Label text="OTP Code"/>
                <TextField fx:id="otpField" promptText="Enter the OTP shown in the backend console"/>
            </VBox>

            <VBox spacing="5">
                <Label text="New Password"/>
                <PasswordField fx:id="newPasswordField" promptText="8+ chars, uppercase, lowercase, number"
                               onKeyReleased="#handlePasswordInput"/>
            </VBox>

            <Label fx:id="resetPasswordStrengthLabel" text="" styleClass="password-strength"/>

            <VBox spacing="5">
                <Label text="Confirm Password"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"
                               onKeyReleased="#handlePasswordInput"/>
            </VBox>

            <Label fx:id="resetPasswordMatchLabel" text="" styleClass="password-strength"/>

            <Label fx:id="resetInfoLabel" text="" styleClass="label-success" wrapText="true"/>
            <Label fx:id="resetErrorLabel" text="" styleClass="label-error" wrapText="true"/>

            <Button text="Reset Password" styleClass="btn-primary" 
                    onAction="#handleResetPassword" maxWidth="Infinity"/>

            <ProgressIndicator fx:id="resetProgressIndicator" progress="-1" 
                              visible="false" maxWidth="30" maxHeight="30"/>
        </VBox>

        <!-- Login Link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Remember your password?" styleClass="label"/>
            <Button text="Login" styleClass="btn-secondary" onAction="#handleBack"/>
        </HBox>
    </VBox>
</StackPane>
