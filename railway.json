{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && mvn -DskipTests clean package"
  },
  "deploy": {
    "startCommand": "java -jar backend/target/auth-system-backend-1.0.0.jar",
    "healthcheckPath": "/api/auth/totp/remaining-seconds",
    "healthcheckTimeout": 300
  }
}
